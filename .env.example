# Optional. When set, the maintenance form POSTs multipart data to this URL.
# Expected fields: urgency, residentName, email, optional residentPhone (SMS), residentNotificationChannel (email|sms|both, default both), unit, description, and one or more `photo` file parts (PNG/JPG or MP4/WebM/MOV).
# JSON responses may include `id` or `requestId` for the confirmation message.
# Supabase Edge Function (after `supabase db push` + `functions deploy submit-maintenance-request`): set VITE_SUPABASE_ANON_KEY for `apikey` + `Authorization` headers.
# VITE_MAINTENANCE_API_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/submit-maintenance-request
# VITE_MAINTENANCE_API_URL=https://api.example.com/v1/maintenance-requests

# Optional. POST JSON { "ticketId", "comment", "residentUserId" (optional) } with optional `Authorization: Bearer` from Supabase.
# Use the same ticket id your create endpoint returns (not the display reference if you use one).
# VITE_MAINTENANCE_TICKET_COMMENT_URL=https://api.example.com/v1/maintenance-requests/comment

# Optional. GET returns JSON for this ticket, e.g. { "status": "in_progress", "detail": "Technician ETA 3pm" }.
# Same `ticketId` as your create endpoint. Maps to the success-page timeline (scheduled / in_progress / resolved / …).
# VITE_MAINTENANCE_TICKET_STATUS_URL=https://api.example.com/v1/maintenance-requests/status
# Optional poll interval in ms (minimum 5000). Default 45000.
# VITE_MAINTENANCE_TICKET_STATUS_POLL_MS=60000

# If the URL is a Supabase Edge Function (…supabase.co/functions/v1/…), set VITE_SUPABASE_ANON_KEY too:
# the client sends Authorization (user JWT) + apikey (anon). The function validates the session server-side (see config.toml).
# Optional: POST JSON { "description": "..." } → your AI proxy returns JSON, e.g.:
#   { "questions": ["...","..."],
#     "issueType": "Plumbing", "room": "Kitchen", "appliance": "Sink",
#     "severity": "moderate", "urgency": "normal",
#     "normalizedSummary": "Kitchen sink leaking under cabinet.",
#     "aiSummary": "Long prose for the review screen (**bold** segments supported)." }
# Or nest fields under "parsed": { ... }. Keys may use snake_case (see issueAnalysis.ts).
# Optional aliases for the review summary: reviewSummary, generatedSummary, maintenanceSummary.
# VITE_ISSUE_CLARIFY_API_URL=https://api.example.com/v1/maintenance/clarify
# Optional. Send Broadcast Message modal: POST send-now payload to this URL.
# For Supabase Edge Functions, set to:
# VITE_BROADCAST_SEND_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/send-broadcast
# Optional. Schedule flow: POST { action: "schedule", schedule: { scheduledAtIso }, ...same fields as send }.
# Persists to broadcast_notifications (status scheduled). Cron should POST run-scheduled-broadcasts.
# VITE_BROADCAST_SCHEDULE_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/schedule-broadcast

# Supabase (Vite uses VITE_ prefix, not NEXT_PUBLIC_)
# When set, Confirm on the review step requires a matching signed-in user or email OTP (production / preview only; skipped during `npm run dev`).
# Resident sign-in uses in-app OTP (see VerifyIdentityModal). One-time dashboard setup (applies to all residents):
# Auth → Email → edit Confirm signup AND Magic link to include {{ .Token }} — see supabase/AUTH_EMAIL_OTP.md (Option A).
# Add your dev URL under Auth → URL Configuration (Site URL + Redirect URLs). Never ship service_role to the browser.
# Include both dev and local preview origins if you test admin login after `npm run build && npm run preview` (preview defaults to port 4173; `npm run dev` uses 5173):
#   http://localhost:5173/**   http://127.0.0.1:5173/**
#   http://localhost:4173/**   http://127.0.0.1:4173/**
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# Admin login (/admin/login): create Auth user with email admin@property-admin.auth.local and your password
# (username "admin" maps to that email — see src/lib/adminAuth.ts). Apply RLS migration for authenticated reads.

# Optional webhooks after a ticket is created (POST JSON: ticketId, residentName, email, unit, description, urgency).
# Browser-safe only — do NOT put Twilio/Resend keys behind these URLs. Vendor email/SMS runs inside the
# submit-maintenance-request Edge Function with Supabase secrets; see supabase/VENDOR_NOTIFICATIONS.md.
# VITE_RECURRING_ISSUE_API_URL=https://api.example.com/v1/maintenance/recurring-scan
# VITE_VENDOR_ROUTING_API_URL=https://api.example.com/v1/maintenance/route-vendor

# Optional. Admin Request Management: persist vendor override + re-notify (requires ticket UUID on the row).
# Set Edge secret ADMIN_REASSIGN_SECRET to the same value as VITE_ADMIN_REASSIGN_SECRET (treat as sensitive).
# For hosted Supabase Functions URLs, set VITE_SUPABASE_ANON_KEY as well: the client sends apikey + Authorization (anon JWT)
# and passes the admin secret in x-admin-reassign-secret (Bearer-only secret hits 401 at the gateway).
# VITE_ADMIN_REASSIGN_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/admin-reassign-vendor
# VITE_ADMIN_REASSIGN_SECRET=your-long-random-secret

# Optional. POST recommend-vendor-alternatives (same ADMIN_REASSIGN_SECRET / x-admin-reassign-secret as admin reassign). AI ranks category-matched vendors when OPENAI_API_KEY is set on the function.
# If unset, the admin UI uses `${VITE_SUPABASE_URL}/functions/v1/recommend-vendor-alternatives` when VITE_SUPABASE_URL is set (deploy the function first).
# VITE_VENDOR_RECOMMEND_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/recommend-vendor-alternatives
# Optional. POST discover-external-vendors (same ADMIN_REASSIGN_SECRET). Defaults from VITE_SUPABASE_URL when unset.
# VITE_DISCOVER_EXTERNAL_VENDORS_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/discover-external-vendors
# Optional override (ms): after assignment, wait this long before showing “vendor delayed” AI card. Default 0 in dev, 1 hour in prod.
# VITE_VENDOR_DELAY_AI_MS=3600000

# --- Not for .env (set as Supabase Edge Function secrets, not VITE_*) ---
# RESEND_API_KEY, RESEND_FROM_EMAIL (optional; default noreply@assetwise.site — domain must be verified in Resend), TWILIO_*, ADMIN_REASSIGN_SECRET, OPENAI_API_KEY
# discover-external-vendors (Google Places Text Search + Yelp Fusion): GOOGLE_PLACES_API_KEY, YELP_API_KEY; optional EXTERNAL_VENDOR_SEARCH_LOCATION when ticket unit is not a searchable place
# Scheduled broadcasts: deploy run-scheduled-broadcasts; schedule Supabase cron (or external) to POST e.g. every minute:
#   curl -X POST "https://YOUR_PROJECT_REF.supabase.co/functions/v1/run-scheduled-broadcasts" -H "Authorization: Bearer YOUR_SECRET"
# Set Edge secret RUN_SCHEDULED_BROADCASTS_SECRET to the same Bearer value (if unset, the function accepts any POST — dev only).
# Optional cron: VENDOR_DELAY_CRON_SECRET — Bearer for POST vendor-delayed-auto-reassign (Supabase Scheduled Functions or external scheduler). If unset, the same ADMIN_REASSIGN_SECRET Bearer is accepted.
# Vendor portal deep links + email Accept/Decline (see supabase/VENDOR_NOTIFICATIONS.md):
# APP_URL=https://your-production-app.example.com
# For vendor links in email: APP_URL's port must match your running app — npm run dev = 5173, npm run preview = 4173.
# If APP_URL is :4173 but only dev (:5173) is running, links will show "can't be reached". Also avoid bare localhost for
# phones/mail clients; use LAN "Network" URL, tunnel, or production. See supabase/VENDOR_NOTIFICATIONS.md.
# VENDOR_EMAIL_ACTION_SECRET=your-long-random-secret-for-hmac
# Optional: VENDOR_RESPOND_FN_URL=https://YOUR_PROJECT.supabase.co/functions/v1/vendor-respond
# Same providers are used for resident lifecycle email/SMS (ticket submitted, vendor assigned, in progress, completed).
# See supabase/VENDOR_NOTIFICATIONS.md
